{
  "info": {
    "name": "tadeumendonca-api",
    "description": "Smoke + contract regression for the BFF. Black-box checks against a real deployed environment (or a local server). Parametrized by environment (local/staging/production) via {{base_url}}; authenticated writes use {{token}} (a test user's Cognito access token, injected as an env var). Run with newman — see package.json `api-test`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Smoke: GET /profile (public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/profile"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('has name + headline (snake_case shape)', () => { pm.expect(b).to.have.property('name'); pm.expect(b).to.have.property('headline'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Smoke: GET /posts (unified feed)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/posts?limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('items is an array', () => pm.expect(b.items).to.be.an('array'));",
              "pm.test('every item carries a kind discriminator', () => b.items.forEach(i => pm.expect(['post','article']).to.include(i.kind)));"
            ]
          }
        }
      ]
    },
    {
      "name": "Smoke: GET /articles (blog list)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/articles?limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "pm.test('items is an array', () => pm.expect(pm.response.json().items).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Smoke: GET /polls (aside widget)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/polls?limit=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "pm.test('items is an array', () => pm.expect(pm.response.json().items).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Smoke: GET /shortlinks/demoart resolves the seeded article",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/shortlinks/demoart"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('an article short link points at the slug (so /p/<code> -> /blog/<slug>)', () => { pm.expect(b.type).to.eql('article'); pm.expect(b.target_id).to.eql('building-serverless-on-aws'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth: POST /posts without a token -> 401",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"smoke\",\"body\":\"smoke\",\"published\":false}"
        },
        "url": "{{base_url}}/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('admin write is rejected without a token — the API Gateway Cognito authorizer returns 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): POST /posts creates a draft (only when {{token}} is set)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"regression draft\",\"body\":\"created by the api regression smoke; deleted next\",\"published\":false}"
        },
        "url": "{{base_url}}/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token')) { console.log('no {{token}} — skipping admin write'); return; }",
              "pm.test('admin can create a post (201)', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('created_post_id', pm.response.json().post_id);",
              "pm.test('the created post is a draft (kept out of the public feed)', () => pm.expect(pm.response.json().published).to.eql(false));"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): DELETE the draft (cleanup; only when {{token}} is set)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/posts/{{created_post_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token') || !pm.collectionVariables.get('created_post_id')) { console.log('no token / nothing created — skipping cleanup'); return; }",
              "pm.test('admin can delete the post (204)', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): POST /articles mints a share short_code (only when {{token}} is set)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"regression article\",\"body\":\"created by the api regression smoke; deleted next\",\"tag\":\"test\",\"published\":false}"
        },
        "url": "{{base_url}}/articles"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token')) { console.log('no {{token}} — skipping admin write'); return; }",
              "pm.test('admin can create an article (201)', () => pm.response.to.have.status(201));",
              "const b = pm.response.json();",
              "pm.collectionVariables.set('created_article_slug', b.slug);",
              "pm.test('the article carries a share short_code (/p/<code>)', () => pm.expect(b.short_code).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): DELETE the article (cleanup; only when {{token}} is set)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/articles/{{created_article_slug}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token') || !pm.collectionVariables.get('created_article_slug')) { console.log('no token / nothing created — skipping cleanup'); return; }",
              "pm.test('admin can delete the article (204)', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): POST /polls creates a draft (only when {{token}} is set)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"question\":\"regression poll\",\"options\":[{\"label\":\"A\"},{\"label\":\"B\"}],\"published\":false}"
        },
        "url": "{{base_url}}/polls"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token')) { console.log('no {{token}} — skipping admin write'); return; }",
              "pm.test('admin can create a poll (201)', () => pm.response.to.have.status(201));",
              "const b = pm.response.json();",
              "pm.collectionVariables.set('created_poll_id', b.poll_id);",
              "pm.test('options get server-generated ids', () => pm.expect(b.options[0].id).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth (admin): DELETE the poll (cleanup; only when {{token}} is set)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/polls/{{created_poll_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token') || !pm.collectionVariables.get('created_poll_id')) { console.log('no token / nothing created — skipping cleanup'); return; }",
              "pm.test('admin can delete the poll (204)', () => pm.response.to.have.status(204));"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth: GET /me returns my profile (only when {{token}} is set)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('token')) { console.log('no {{token}} — skipping authed /me'); return; }",
              "pm.test('GET /me returns 200', () => pm.response.to.have.status(200));",
              "pm.test('profile carries cognito_sub', () => pm.expect(pm.response.json().cognito_sub).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ]
    }
  ]
}
