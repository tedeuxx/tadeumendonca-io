{
  "name": "tadeumendonca-fed",
  "version": "0.1.3",
  "description": "Static SPA for tadeumendonca.io — React + Vite + Tailwind.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "build": "tsc --noEmit && vite build && npm run gen-sitemap",
    "build:static": "npm run build && npm run prerender",
    "prerender": "node scripts/prerender.mjs",
    "gen-sitemap": "node scripts/gen-sitemap.mjs",
    "preview": "vite preview",
    "gen-og": "node scripts/gen-og-default.mjs",
    "gen-icons": "node scripts/gen-icons.mjs",
    "audit": "audit-ci --config audit-ci.jsonc",
    "e2e": "playwright test",
    "e2e:local": "E2E_ENV=local playwright test",
    "e2e:staging": "E2E_ENV=staging playwright test",
    "e2e:production": "E2E_ENV=production playwright test"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@fontsource/space-grotesk": "^5.3.0",
    "@tanstack/react-query": "^5.101.4",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.3.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.4",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.3",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.4.9",
    "vitest": "^2.1.3"
  }
}
